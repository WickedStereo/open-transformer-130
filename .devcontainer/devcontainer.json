{
  "name": "open-transformer-130",
  "build": {
    "dockerfile": "../docker/Dockerfile",
    "context": ".."
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",
  "remoteUser": "dev",
  "mounts": [
    "source=${localEnv:HOME}/pdk,target=/pdk,type=bind,consistency=cached",
    "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind,consistency=cached",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "containerEnv": {
    "PDK_ROOT": "/pdk",
    "DOCKER_HOST": "unix:///var/run/docker.sock",
    "HOST_WORKSPACE": "${localWorkspaceFolder}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.cpptools",
        "eirikpre.systemverilog"
      ]
    }
  },
  "postCreateCommand": "python3 -m pip install --user --upgrade pip && python3 -m pip install --user openlane cocotb pyuvm numpy torch onnx matplotlib pytest"
}
